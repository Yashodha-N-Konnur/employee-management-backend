          }
        },
        {
          "name": "Get All Departments",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.expect(pm.response.code).to.equal(200));",
                  "pm.test('Data is array', () => pm.expect(pm.response.json().data).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/v1/departments", "host": ["{{base_url}}"], "path": ["api","v1","departments"] }
          }
        },
        {
          "name": "Get Department by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.expect(pm.response.code).to.equal(200));",
                  "pm.test('Has id field', () => pm.expect(pm.response.json().data.id).to.exist);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/v1/departments/{{dept_id}}", "host": ["{{base_url}}"], "path": ["api","v1","departments","{{dept_id}}"] }
          }
        },
        {
          "name": "Update Department",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"departmentName\": \"Platform Engineering\",\n  \"departmentCode\": \"PLATFORM\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/departments/{{dept_id}}", "host": ["{{base_url}}"], "path": ["api","v1","departments","{{dept_id}}"] }
          }
        },
        {
          "name": "Search Departments",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/departments/search?name=Eng",
              "host": ["{{base_url}}"], "path": ["api","v1","departments","search"],
              "query": [{ "key": "name", "value": "Eng" }]
            }
          }
        },
        {
          "name": "Delete Department",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.expect(pm.response.code).to.equal(200));",
                  "pm.test('Deleted successfully', () => pm.expect(pm.response.json().message).to.include('deleted'));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/api/v1/departments/{{dept_id}}", "host": ["{{base_url}}"], "path": ["api","v1","departments","{{dept_id}}"] }
          }
        },
        {
          "name": "Create Department – Duplicate Code (409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 409 Conflict', () => pm.expect(pm.response.code).to.equal(409));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"departmentName\": \"Engineering Duplicate\",\n  \"departmentCode\": \"ENG\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/departments", "host": ["{{base_url}}"], "path": ["api","v1","departments"] }
          }
        }
      ]
    },
