              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.expect(pm.response.code).to.equal(201));",
                  "pm.test('Email matches', () => pm.expect(pm.response.json().data.email).to.equal('alex.turner@company.com'));",
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('emp_id', pm.response.json().data.id);",
                  "    console.log('Employee ID saved:', pm.response.json().data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Alex\",\n  \"lastName\": \"Turner\",\n  \"email\": \"alex.turner@company.com\",\n  \"phone\": \"9876543299\",\n  \"salary\": 92000.00,\n  \"joiningDate\": \"2024-01-15\",\n  \"status\": \"ACTIVE\",\n  \"departmentId\": 1,\n  \"roleId\": 1\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/employees", "host": ["{{base_url}}"], "path": ["api","v1","employees"] }
          }
        },
        {
          "name": "Get All Employees (Paginated)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.expect(pm.response.code).to.equal(200));",
                  "pm.test('Paged response', () => {",
                  "    const d = pm.response.json().data;",
                  "    pm.expect(d.content).to.be.an('array');",
                  "    pm.expect(d.totalElements).to.be.a('number');",
                  "    pm.expect(d.totalPages).to.be.a('number');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/employees?page=0&size=5&sortBy=firstName&sortDir=asc",
              "host": ["{{base_url}}"], "path": ["api","v1","employees"],
              "query": [
                { "key": "page",    "value": "0" },
                { "key": "size",    "value": "5" },
                { "key": "sortBy",  "value": "firstName" },
                { "key": "sortDir", "value": "asc" }
              ]
            }
